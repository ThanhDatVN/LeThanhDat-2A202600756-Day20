# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose "openai" or "ollama" (default: openai)
LLM_PROVIDER=openai

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama local model (used when LLM_PROVIDER=ollama)
# 1. Install Ollama: https://ollama.com/
# 2. Pull a model:  ollama pull llama3.2
# 3. Set below and LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Optional tracing providers ────────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=multi-agent-research-lab
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Optional search provider ──────────────────────────────────────────────────
# If not set, a built-in mock search is used automatically
TAVILY_API_KEY=

# ── Runtime config ────────────────────────────────────────────────────────────
APP_ENV=local
LOG_LEVEL=INFO
MAX_ITERATIONS=6
TIMEOUT_SECONDS=60
